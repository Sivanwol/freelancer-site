# Site URL - Update this with your actual domain
NEXT_PUBLIC_SITE_URL=https://www.devco-solution.online

# Google Analytics 4 Measurement ID (optional - leave empty to disable)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google Tag Manager container ID (optional - defaults to GTM-MN4LJ534)
NEXT_PUBLIC_GTM_ID=GTM-MN4LJ534

# Attio CRM API token (server-only — required for contact form submissions)
# Required scopes (Attio → Workspace settings → Developers → integration → Scopes):
# - Object Configuration: Read
# - Records: Read/Write for People, Companies, and Deals
# - User Management: Read (needed to assign deal owner by email)
# Also activate the Deals object if it is currently deactivated.
ATTIO_API_KEY=
